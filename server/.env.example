# ========================
# This file is a template for other developers
# ========================

# ========================
# SERVER CONFIG
# ========================
PORT=5000
NODE_ENV=development

# ========================
# DATABASE CONFIG (XAMPP MySQL)
# ========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=quickbite_db
DB_USER=root
DB_PASSWORD=your_db_password

# ========================
# JWT / AUTH CONFIG
# ========================
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# ========================
# SIMULATED PAYMENT (optional)
# ========================
SIMULATED_PAYMENT_API_KEY=your_payment_key